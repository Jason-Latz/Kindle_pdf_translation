{
  "name": "book-translator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build",
    "cleanup:intermediate-blobs": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --env-file-if-exists=.env.local scripts/cleanup-intermediate-blobs.ts"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "@vercel/queue": "^0.1.7",
    "epub-gen-memory": "^1.1.2",
    "js-tiktoken": "^1.0.15",
    "next": "^15.5.19",
    "openai": "^5.0.0",
    "pdfjs-dist": "^4.10.38",
    "postgres": "^3.4.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stopword": "^3.1.5",
    "tailwindcss": "^3.4.7",
    "workflow": "^4.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/stopword": "^2.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.15",
    "typescript": "^5.5.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "devalue": "5.8.1",
    "undici": "7.24.8",
    "ws": "8.21.0"
  }
}
